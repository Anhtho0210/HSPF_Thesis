# Copy this file to .env and fill in your actual API keys.
# NEVER commit your real .env file to version control.

# Google Gemini API key — used by Agent 1, Agent 3, Agent 6
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Perplexity API key — used by Agent 4 (document checklist web search)
# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
